# =============================================================================
# GitHub App Configuration
# =============================================================================

# Your GitHub App's ID (found on the App settings page)
GITHUB_APP_ID=123456

# Path to the GitHub App's private key (.pem file)
GITHUB_PRIVATE_KEY_PATH=/app/private-key.pem

# Webhook secret configured in the GitHub App settings
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# =============================================================================
# AI Model Configuration
# =============================================================================

# Path to the GGUF model file for local inference
AI_MODEL_PATH=/app/models/model.gguf

# Maximum tokens for AI generation (keep low for memory efficiency)
AI_MAX_TOKENS=1024

# Number of context tokens the model supports
AI_CONTEXT_SIZE=2048

# Number of CPU threads for inference (0 = auto-detect)
AI_THREADS=0

# =============================================================================
# Application Settings
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Use mock AI engine for testing (true/false)
USE_MOCK_ENGINE=false

# Maximum diff size in characters to send to AI per chunk
MAX_DIFF_CHUNK_SIZE=3000
